{
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": ".",
  "framework": "static",
  "env": {
    "VERCEL_ENV": "production"
  },
  "headers": [
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.+)",
      "destination": "/$1.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
